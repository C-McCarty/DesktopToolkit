<Window x:Class="AnimatedDesktopBackground.Ui.ManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Animated Desktop Background"
        Width="740" Height="580"
        WindowStartupLocation="CenterScreen"
        Background="#15151A">
    <Window.Resources>
        <!-- High-contrast palette -->
        <SolidColorBrush x:Key="TextPrimary"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#C8CCD6"/>
        <SolidColorBrush x:Key="CardBg"        Color="#262630"/>
        <SolidColorBrush x:Key="Accent"        Color="#3B97F0"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Background" Value="#3A3A46"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Light, high-contrast ComboBox. The ItemTemplate forces dark text so it never renders as
             white-on-white under the system dark theme (closed box and dropdown both use it). -->
        <DataTemplate x:Key="ComboItemTemplate">
            <TextBlock Text="{Binding}" Foreground="#15151A"/>
        </DataTemplate>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#15151A"/>
            <Setter Property="Background" Value="#E8EAF0"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemTemplate" Value="{StaticResource ComboItemTemplate}"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#15151A"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Animated Desktop Background" FontSize="22" FontWeight="Bold"/>
            <TextBlock Text="Assign a GIF or video to one or more displays. Each plays behind your desktop icons."
                       Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,3,0,0"/>
        </StackPanel>

        <!-- Assignment rows -->
        <DockPanel Grid.Row="1">
            <Button DockPanel.Dock="Top" HorizontalAlignment="Left" Content="+ Add wallpaper"
                    Click="OnAddAssignment" Margin="0,0,0,10" Background="{StaticResource Accent}"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Assignments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBg}" CornerRadius="8" Padding="14" Margin="0,0,0,10">
                                    <StackPanel>
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Top">
                                                <Button Content="Browse…" Click="OnBrowse" Tag="{Binding}"/>
                                                <Button Content="Clear" Click="OnClear" Tag="{Binding}"/>
                                                <Button Content="Remove" Click="OnRemove" Tag="{Binding}" Background="#5C1A1A"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{Binding MediaDisplay}" FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{StaticResource TextPrimary}" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <CheckBox Content="Mute" IsChecked="{Binding Muted}" VerticalAlignment="Center"
                                                              Foreground="{StaticResource TextPrimary}"/>
                                                    <TextBlock Text="Fill:" Margin="18,0,6,0" VerticalAlignment="Center"
                                                               Foreground="{StaticResource TextPrimary}"/>
                                                    <ComboBox Width="120" VerticalAlignment="Center"
                                                              ItemsSource="{Binding FillModes}" SelectedItem="{Binding FillMode}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </DockPanel>
                                        <TextBlock Text="Spans which displays:" Foreground="{StaticResource TextSecondary}"
                                                   FontSize="12" Margin="0,10,0,4"/>
                                        <ItemsControl ItemsSource="{Binding Monitors}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Label}" IsChecked="{Binding IsChecked}"
                                                              Margin="0,0,16,4" Foreground="{StaticResource TextPrimary}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="A display can belong to only one wallpaper — checking it here unchecks it elsewhere."
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="2,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Global options -->
        <Border Grid.Row="2" Background="{StaticResource CardBg}" CornerRadius="8" Padding="14" Margin="0,4,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <!-- "Start with Windows" is configured from the suite dashboard (host-owned). -->
                    <CheckBox Content="Pause when a fullscreen app/game is running" IsChecked="{Binding PauseOnFullscreen}"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <CheckBox Content="Start minimized to tray" IsChecked="{Binding StartMinimized}"/>
                    <CheckBox Content="Play wallpaper on launch" IsChecked="{Binding PlayOnStartup}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="Engine:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox Width="150" ItemsSource="{Binding Engines}" SelectedItem="{Binding Engine}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Actions -->
        <Grid Grid.Row="3">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="Identify Displays" Click="OnIdentify" Margin="0,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Stop" Click="OnStop"/>
                <Button Content="Apply &amp; Play" Click="OnApplyPlay"/>
                <Button Content="Save &amp; Close" Click="OnSaveClose" Background="{StaticResource Accent}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
