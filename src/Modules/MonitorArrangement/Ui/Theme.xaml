<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBg" Color="#FF0D0D1A" />
    <SolidColorBrush x:Key="CanvasBg" Color="#FF1A1A2E" />
    <SolidColorBrush x:Key="SidebarBg" Color="#FF16213E" />
    <SolidColorBrush x:Key="ToolbarBg" Color="#FF0F3460" />
    <SolidColorBrush x:Key="TextFg" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MutedFg" Color="#FFAAAAAA" />
    <SolidColorBrush x:Key="EntryBg" Color="#FF1A3A6E" />
    <SolidColorBrush x:Key="Separator" Color="#FF333366" />
    <SolidColorBrush x:Key="BtnNormalBg" Color="#FF1E2A4A" />
    <SolidColorBrush x:Key="BtnApplyBg" Color="#FF1A5C38" />
    <SolidColorBrush x:Key="BtnDangerBg" Color="#FF5C1A1A" />
    <SolidColorBrush x:Key="BtnHover" Color="#FF2A3A6A" />

    <Style TargetType="Button" x:Key="ToolButton">
        <Setter Property="Background" Value="{StaticResource BtnNormalBg}" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Margin" Value="2,4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource BtnHover}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TextBox" x:Key="CoordBox">
        <Setter Property="Background" Value="{StaticResource EntryBg}" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="CaretBrush" Value="{StaticResource TextFg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="5,3" />
        <Setter Property="Width" Value="80" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="CheckBox" x:Key="ToolCheck">
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="6,0" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="12" />
    </Style>

</ResourceDictionary>
