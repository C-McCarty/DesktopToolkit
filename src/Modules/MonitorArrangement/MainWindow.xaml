<Window x:Class="MonitorArrangement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MonitorArrangement.Controls"
        Title="Monitor Arrangement" Height="640" Width="1100" MinHeight="400" MinWidth="700"
        Background="{StaticResource WindowBg}" FontFamily="Segoe UI">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource ToolbarBg}">
            <WrapPanel Orientation="Horizontal" Margin="4,2">
                <Button Content="Apply" Style="{StaticResource ToolButton}" Background="{StaticResource BtnApplyBg}" Click="Apply_Click" />
                <Border Width="1" Background="{StaticResource Separator}" Margin="4,4" />
                <Button Content="Identify" Style="{StaticResource ToolButton}" Click="Identify_Click" />
                <Button Content="Reset" Style="{StaticResource ToolButton}" Background="{StaticResource BtnDangerBg}" Click="Reset_Click" />
                <Border Width="1" Background="{StaticResource Separator}" Margin="4,4" />
                <Button x:Name="UndoBtn" Content="↶ Undo" Style="{StaticResource ToolButton}" Click="Undo_Click" />
                <Button x:Name="RedoBtn" Content="↷ Redo" Style="{StaticResource ToolButton}" Click="Redo_Click" />
                <Border Width="1" Background="{StaticResource Separator}" Margin="4,4" />
                <Button Content="－" Style="{StaticResource ToolButton}" Click="ZoomOut_Click" />
                <Button Content="＋" Style="{StaticResource ToolButton}" Click="ZoomIn_Click" />
                <Button Content="Fit" Style="{StaticResource ToolButton}" Click="Fit_Click" />
                <Border Width="1" Background="{StaticResource Separator}" Margin="4,4" />
                <Button Content="Save Profile" Style="{StaticResource ToolButton}" Click="SaveProfile_Click" />
                <Button Content="Load Profile" Style="{StaticResource ToolButton}" Click="LoadProfile_Click" />
                <Button Content="Copy Diag" Style="{StaticResource ToolButton}" Click="CopyDiag_Click" />
                <Border Width="1" Background="{StaticResource Separator}" Margin="4,4" />
                <CheckBox x:Name="SnapEdgesCheck" Content="Snap Edges" Style="{StaticResource ToolCheck}"
                          IsChecked="True" Checked="SnapEdges_Changed" Unchecked="SnapEdges_Changed" />
                <CheckBox x:Name="SnapGridCheck" Content="Grid" Style="{StaticResource ToolCheck}"
                          IsChecked="True" Checked="SnapGrid_Changed" Unchecked="SnapGrid_Changed" />
                <TextBox x:Name="GridSizeBox" Style="{StaticResource CoordBox}" Width="50" Text="120"
                         VerticalAlignment="Center" TextChanged="GridSize_Changed" />
                <TextBlock Text="px" Foreground="{StaticResource MutedFg}" VerticalAlignment="Center" Margin="2,0" />
            </WrapPanel>
        </Border>

        <!-- Sidebar -->
        <Border DockPanel.Dock="Right" Background="{StaticResource SidebarBg}" Width="240">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Monitors" Foreground="{StaticResource MutedFg}"
                           FontWeight="Bold" FontSize="11" Margin="10,8,10,4" />
                <!-- Auto scrollbar: scrolls anywhere over the panel, only when content overflows. -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="RowsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8,4">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="16" Background="{Binding ColorBrush}" CornerRadius="2" />
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource TextFg}"
                                                   FontWeight="Bold" FontSize="12" Margin="6,0,0,0"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding ResolutionLine}" Foreground="{StaticResource MutedFg}"
                                               FontSize="11" Margin="0,3,0,2" />
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="X" Foreground="{StaticResource MutedFg}"
                                                   VerticalAlignment="Center" Margin="2,0,6,0" />
                                        <TextBox Grid.Column="1" Style="{StaticResource CoordBox}" HorizontalAlignment="Left"
                                                 Text="{Binding X, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                                    </Grid>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Y" Foreground="{StaticResource MutedFg}"
                                                   VerticalAlignment="Center" Margin="2,0,6,0" />
                                        <TextBox Grid.Column="1" Style="{StaticResource CoordBox}" HorizontalAlignment="Left"
                                                 Text="{Binding Y, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
                                    </Grid>
                                    <Border Height="1" Background="{StaticResource Separator}" Margin="0,6,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Canvas -->
        <controls:MonitorCanvas x:Name="Canvas" />
    </DockPanel>
</Window>
