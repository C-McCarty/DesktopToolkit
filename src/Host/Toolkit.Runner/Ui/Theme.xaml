<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette carried over from the original Monitor Arrangement tool for visual continuity. -->
    <Color x:Key="WindowBgColor">#FF0D0D1A</Color>
    <Color x:Key="CardBgColor">#FF16213E</Color>
    <Color x:Key="AccentColor">#FF0F3460</Color>
    <Color x:Key="AccentHiColor">#FF4E9AF1</Color>

    <SolidColorBrush x:Key="WindowBg" Color="{StaticResource WindowBgColor}" />
    <SolidColorBrush x:Key="CardBg" Color="{StaticResource CardBgColor}" />
    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHi" Color="{StaticResource AccentHiColor}" />
    <SolidColorBrush x:Key="TextFg" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="MutedFg" Color="#FFAAAAAA" />
    <SolidColorBrush x:Key="Separator" Color="#FF333366" />

    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <Style TargetType="Button" x:Key="ToolkitButton">
        <Setter Property="Background" Value="{StaticResource Accent}" />
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource AccentHi}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Subtle secondary button (Reset / Open folder / Rescan). -->
    <Style TargetType="Button" x:Key="SubtleButton" BasedOn="{StaticResource ToolkitButton}">
        <Setter Property="Background" Value="#FF1E2A4A" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF2A3A6A" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Destructive button (Remove). -->
    <Style TargetType="Button" x:Key="DangerButton" BasedOn="{StaticResource ToolkitButton}">
        <Setter Property="Background" Value="#FF5C1A1A" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FF7A2222" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <SolidColorBrush x:Key="EntryBg" Color="#FF1A3A6E" />

    <!-- Dark tab headers. -->
    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource TextFg}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border Name="Bd" Background="{StaticResource WindowBg}" Padding="16,8" Margin="0,0,2,0"
                            BorderThickness="0,0,0,2" BorderBrush="Transparent">
                        <ContentPresenter ContentSource="Header" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource CardBg}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentHi}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
