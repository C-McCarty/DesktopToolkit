<Window x:Class="Toolkit.Runner.Ui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Module settings" Height="420" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBg}"
        FontFamily="Segoe UI">

    <DockPanel Margin="0">
        <Border DockPanel.Dock="Top" Background="{StaticResource Accent}" Padding="16,12">
            <StackPanel>
                <TextBlock x:Name="TitleText" Foreground="{StaticResource TextFg}"
                           FontSize="16" FontWeight="Bold" />
                <TextBlock x:Name="SubtitleText" Foreground="{StaticResource MutedFg}" FontSize="11" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Background="{StaticResource CardBg}" Padding="12,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Save" Style="{StaticResource ToolkitButton}" Click="Save_Click" />
                <Button Content="Cancel" Style="{StaticResource ToolkitButton}" Click="Cancel_Click" />
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel x:Name="FieldsPanel" />
        </ScrollViewer>
    </DockPanel>
</Window>
