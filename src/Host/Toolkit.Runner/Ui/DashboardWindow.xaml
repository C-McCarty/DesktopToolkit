<Window x:Class="Toolkit.Runner.Ui.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop Toolkit" Height="600" Width="760"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}"
        FontFamily="Segoe UI">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Accent}" Padding="18,14">
            <StackPanel>
                <TextBlock Text="Desktop Toolkit" Foreground="{StaticResource TextFg}"
                           FontSize="20" FontWeight="Bold" />
                <TextBlock Text="A better desktop for Windows 11"
                           Foreground="{StaticResource MutedFg}" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Footer -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource CardBg}" Padding="14,8">
            <DockPanel>
                <CheckBox x:Name="StartWithWindowsCheck" Content="Start Desktop Toolkit with Windows"
                          Foreground="{StaticResource TextFg}" VerticalAlignment="Center"
                          Checked="StartWithWindows_Changed" Unchecked="StartWithWindows_Changed" />
                <TextBlock x:Name="EmptyHint" DockPanel.Dock="Right" Foreground="{StaticResource MutedFg}"
                           FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" />
            </DockPanel>
        </Border>

        <TabControl Background="{StaticResource WindowBg}" BorderThickness="0" Padding="0">
            <!-- ============================ INSTALLED ============================ -->
            <TabItem Header="Installed">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="12,10,12,0">
                        <Button Content="Open modules folder" Style="{StaticResource SubtleButton}"
                                Click="OpenModulesFolder_Click" />
                        <Button Content="Rescan" Style="{StaticResource SubtleButton}" Click="Rescan_Click" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                        <ItemsControl x:Name="ModuleList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardBg}" CornerRadius="6"
                                            Padding="14" Margin="4,4,4,8">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center"
                                                        HorizontalAlignment="Right">
                                                <CheckBox Content="Enabled" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                          Foreground="{StaticResource TextFg}" HorizontalAlignment="Right"
                                                          Visibility="{Binding CanEnable, Converter={StaticResource BoolToVis}}" />
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <Button Content="Configure" Style="{StaticResource ToolkitButton}"
                                                            Command="{Binding ConfigureCommand}" />
                                                    <Button Content="&#x22EE;" FontSize="16" Padding="10,2"
                                                            Style="{StaticResource SubtleButton}" Click="Kebab_Click"
                                                            ToolTip="More actions">
                                                        <Button.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="Reset settings"
                                                                          Command="{Binding PlacementTarget.DataContext.ResetCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                <Separator />
                                                                <MenuItem Header="Remove module"
                                                                          Command="{Binding PlacementTarget.DataContext.RemoveCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                            </ContextMenu>
                                                        </Button.ContextMenu>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextFg}"
                                                               FontSize="15" FontWeight="Bold" />
                                                    <Border Background="{StaticResource Accent}" CornerRadius="3"
                                                            Padding="6,1" Margin="8,1,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding KindLabel}" Foreground="{StaticResource MutedFg}"
                                                                   FontSize="10" />
                                                    </Border>
                                                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentHi}"
                                                               FontSize="11" Margin="8,2,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedFg}"
                                                           FontSize="12" TextWrapping="Wrap" Margin="0,4,140,0" />
                                                <TextBlock Text="{Binding Version}" Foreground="{StaticResource MutedFg}"
                                                           FontSize="10" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ============================ CATALOG ============================ -->
            <TabItem Header="Catalog">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="12,10,12,0">
                        <TextBlock Text="Catalog source (GitHub raw catalog.json URL)"
                                   Foreground="{StaticResource MutedFg}" FontSize="11" />
                        <DockPanel Margin="0,4,0,0">
                            <Button DockPanel.Dock="Right" Content="Install from .zip…"
                                    Style="{StaticResource SubtleButton}" Click="InstallFromZip_Click" />
                            <Button DockPanel.Dock="Right" Content="Refresh" Style="{StaticResource ToolkitButton}"
                                    Click="RefreshCatalog_Click" />
                            <TextBox x:Name="CatalogUrlBox" VerticalContentAlignment="Center"
                                     Background="{StaticResource EntryBg}" Foreground="{StaticResource TextFg}"
                                     CaretBrush="{StaticResource TextFg}" BorderThickness="0" Padding="6,4"
                                     Margin="0,0,6,0" />
                        </DockPanel>
                        <TextBlock x:Name="CatalogStatus" Foreground="{StaticResource MutedFg}"
                                   FontSize="11" Margin="0,8,0,2" TextWrapping="Wrap" />
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,4,12,12">
                        <ItemsControl x:Name="CatalogList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource CardBg}" CornerRadius="6"
                                            Padding="14" Margin="4,4,4,8">
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" VerticalAlignment="Center"
                                                    Content="{Binding ActionLabel}" Style="{StaticResource ToolkitButton}"
                                                    Command="{Binding InstallCommand}" />
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextFg}"
                                                               FontSize="15" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Version}" Foreground="{StaticResource MutedFg}"
                                                               FontSize="11" Margin="8,3,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource MutedFg}"
                                                           FontSize="12" TextWrapping="Wrap" Margin="0,4,80,0" />
                                                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource AccentHi}"
                                                           FontSize="11" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
